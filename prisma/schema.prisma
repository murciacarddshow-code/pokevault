// =============================================================================
// prisma/schema.prisma — PokéVault v2.0
// PostgreSQL for production (Neon) — was sqlite for local dev
// =============================================================================

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// NOTE: Enum-like fields use String for flexibility across environments.
// Valid values documented in comments per model.

// =============================================================================
// AUTH — NextAuth v5 + PrismaAdapter
// =============================================================================

model User {
  id            String    @id @default(cuid())
  email         String?   @unique
  emailVerified DateTime?
  name          String?
  image         String?
  username      String?   @unique
  passwordHash  String?
  // role: USER | MODERATOR | ADMIN
  role          String    @default("USER")
  isBanned      Boolean   @default(false)
  banReason     String?
  bannedAt      DateTime?
  bannedByAdminId String?
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt

  accounts        Account[]
  sessions        Session[]
  wallet          Wallet?
  inventoryItems  InventoryItem[]
  walletTxs       WalletTransaction[]
  packOpenings    PackOpening[]
  instantSells    InstantSell[]
  stripePayments  StripePayment[]
  auditLogs           AuditLog[]
  adminLogs           AdminLog[]           @relation("AdminActor")
  targetAdminLogs     AdminLog[]           @relation("AdminTarget")
  shippingAddresses   ShippingAddress[]
  physicalRedemptions PhysicalRedemption[]

  @@index([email])
  @@index([username])
  @@index([role])
  @@index([isBanned])
  @@index([createdAt])
}

model Account {
  id                String  @id @default(cuid())
  userId            String
  type              String
  provider          String
  providerAccountId String
  refresh_token     String?
  access_token      String?
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String?
  session_state     String?

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
  @@index([userId])
}

model Session {
  id           String   @id @default(cuid())
  sessionToken String   @unique
  userId       String
  expires      DateTime

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
}

model VerificationToken {
  identifier String
  token      String   @unique
  expires    DateTime

  @@unique([identifier, token])
}

// =============================================================================
// WALLET
// =============================================================================

model Wallet {
  id        String   @id @default(cuid())
  userId    String   @unique
  balance   Float    @default(0)
  currency  String   @default("EUR")
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  user         User                @relation(fields: [userId], references: [id], onDelete: Cascade)
  transactions WalletTransaction[]

  @@index([userId])
}

model WalletTransaction {
  id            String   @id @default(cuid())
  walletId      String
  userId        String
  // type: DEPOSIT | PACK_PURCHASE | INSTANT_SELL | REFUND | ADMIN_ADJUSTMENT
  type          String
  // status: PENDING | COMPLETED | FAILED | REFUNDED
  status        String   @default("PENDING")
  amount        Float    // positive = credit, negative = debit
  balanceBefore Float
  balanceAfter  Float
  description   String?
  // JSON metadata stored as String for portability
  metadata      String   @default("{}")
  createdAt     DateTime @default(now())

  wallet        Wallet         @relation(fields: [walletId], references: [id])
  user          User           @relation(fields: [userId], references: [id])
  stripePayment StripePayment?
  instantSell   InstantSell?
  packOpening   PackOpening?

  @@index([walletId])
  @@index([userId])
  @@index([type])
  @@index([status])
  @@index([createdAt])
  @@index([userId, createdAt])
  @@index([userId, type])
}

// =============================================================================
// STRIPE
// =============================================================================

model StripePayment {
  id                    String   @id @default(cuid())
  userId                String
  walletTransactionId   String?  @unique
  stripeSessionId       String   @unique
  stripePaymentIntentId String?  @unique
  // status: PENDING | SUCCEEDED | FAILED | EXPIRED | REFUNDED
  status                String   @default("PENDING")
  amountRequested       Float
  amountReceived        Float?
  currency              String   @default("EUR")
  stripeMetadata        String?  @default("{}")
  createdAt             DateTime @default(now())
  updatedAt             DateTime @updatedAt

  user              User               @relation(fields: [userId], references: [id])
  walletTransaction WalletTransaction? @relation(fields: [walletTransactionId], references: [id])

  @@index([userId])
  @@index([stripeSessionId])
  @@index([stripePaymentIntentId])
  @@index([status])
  @@index([createdAt])
}

// =============================================================================
// CARDS
// =============================================================================

model Card {
  id         String   @id @default(cuid())
  externalId String   @unique
  name       String
  setCode    String
  setName    String
  cardNumber String
  // rarity: COMMON | UNCOMMON | RARE | DOUBLE_RARE | ULTRA_RARE |
  //         ILLUSTRATION_RARE | SPECIAL_ILLUSTRATION_RARE | HYPER_RARE |
  //         SECRET_RARE | GOD_HIT
  rarity     String
  imageUrl   String
  imageHdUrl String?

  currentPrice      Float?
  priceCurrency     String    @default("EUR")
  priceSource       String    @default("NONE")
  priceLastSyncedAt DateTime?
  priceUpdatedAt    DateTime?
  cardmarketUrl     String?
  instantSellPrice  Float?

  isActive  Boolean  @default(true)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  priceHistory   CardPriceHistory[]
  packCardPool   PackCardPool[]
  inventoryItems InventoryItem[]
  openingCards   PackOpeningCard[]
  instantSells        InstantSell[]
  physicalRedemptions PhysicalRedemption[]

  @@unique([setCode, cardNumber])
  @@index([externalId])
  @@index([rarity])
  @@index([setCode])
  @@index([isActive])
}

model CardPriceHistory {
  id         String   @id @default(cuid())
  cardId     String
  price      Float
  currency   String   @default("EUR")
  source     String
  recordedAt DateTime @default(now())

  card Card @relation(fields: [cardId], references: [id], onDelete: Cascade)

  @@index([cardId])
  @@index([cardId, recordedAt])
  @@index([recordedAt])
}

// =============================================================================
// PACKS
// =============================================================================

model Pack {
  id               String   @id @default(cuid())
  slug             String   @unique
  name             String
  description      String?
  imageUrl         String
  // category: pokemon | onepiece | sealed | all
  category         String   @default("pokemon")
  price            Float
  houseEdgePercent Float    @default(30.0)
  cardsPerOpening  Int      @default(5)
  dailyLimit       Int?
  // status: DRAFT | ACTIVE | PAUSED | ARCHIVED
  status           String   @default("DRAFT")
  isFeatured       Boolean  @default(false)
  sortOrder        Int      @default(0)
  calculatedEV         Float?
  calculatedEvRatio    Float?
  calculatedHouseEdge  Float?
  createdAt        DateTime @default(now())
  updatedAt        DateTime @updatedAt

  cardPool PackCardPool[]
  openings PackOpening[]

  @@index([slug])
  @@index([status])
  @@index([isFeatured])
  @@index([category])
  @@index([sortOrder])
}

model PackCardPool {
  id             String @id @default(cuid())
  packId         String
  cardId         String
  dropWeight     Int    @default(100)
  guaranteedSlot Int?

  pack Pack @relation(fields: [packId], references: [id], onDelete: Cascade)
  card Card @relation(fields: [cardId], references: [id])

  @@unique([packId, cardId])
  @@index([packId])
  @@index([cardId])
  @@index([packId, dropWeight])
}

// =============================================================================
// PACK OPENINGS
// =============================================================================

model PackOpening {
  id                  String   @id @default(cuid())
  userId              String
  packId              String
  walletTransactionId String   @unique
  pricePaid           Float
  serverSeed          String
  serverSeedHash      String
  clientSeed          String?
  revealed            Boolean  @default(false)
  createdAt           DateTime @default(now())

  user              User              @relation(fields: [userId], references: [id])
  pack              Pack              @relation(fields: [packId], references: [id])
  walletTransaction WalletTransaction @relation(fields: [walletTransactionId], references: [id])
  cards             PackOpeningCard[]

  @@index([userId])
  @@index([packId])
  @@index([userId, createdAt])
  @@index([packId, createdAt])
  @@index([createdAt])
}

model PackOpeningCard {
  id                     String  @id @default(cuid())
  openingId              String
  cardId                 String
  position               Int
  marketPriceAtDrop      Float?
  instantSellPriceAtDrop Float?

  opening PackOpening @relation(fields: [openingId], references: [id], onDelete: Cascade)
  card    Card        @relation(fields: [cardId], references: [id])

  @@index([openingId])
  @@index([cardId])
  @@index([openingId, position])
}

// =============================================================================
// INVENTORY
// =============================================================================

model InventoryItem {
  id         String   @id @default(cuid())
  userId     String
  cardId     String
  quantity   Int      @default(1)
  obtainedAt DateTime @default(now())
  updatedAt  DateTime @updatedAt

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
  card Card @relation(fields: [cardId], references: [id])

  @@unique([userId, cardId])
  @@index([userId])
  @@index([cardId])
  @@index([userId, obtainedAt])
}

// =============================================================================
// INSTANT SELL
// =============================================================================

model InstantSell {
  id                  String   @id @default(cuid())
  userId              String
  cardId              String
  inventoryItemId     String   // snapshot ref, no FK
  walletTransactionId String   @unique
  sellPrice           Float
  cardMarketPriceRef  Float?
  marginApplied       Float?
  // status: COMPLETED | CANCELLED | REVERSED
  status              String   @default("COMPLETED")
  createdAt           DateTime @default(now())

  user              User              @relation(fields: [userId], references: [id])
  card              Card              @relation(fields: [cardId], references: [id])
  walletTransaction WalletTransaction @relation(fields: [walletTransactionId], references: [id])

  @@index([userId])
  @@index([cardId])
  @@index([userId, createdAt])
  @@index([createdAt])
}

// =============================================================================
// APP SETTINGS — singleton (id = "singleton")
// =============================================================================

model AppSettings {
  id                     String    @id @default("singleton")
  minDepositEur          Float     @default(5)
  maxDepositEur          Float     @default(500)
  instantSellMargin      Float     @default(0.65)
  globalDailyPackLimit   Int       @default(0)
  priceSyncEnabled       Boolean   @default(true)
  priceSyncIntervalHours Int       @default(24)
  lastPriceSyncAt        DateTime?
  preferredPriceSource   String    @default("CARDMARKET")
  maintenanceMode        Boolean   @default(false)
  maintenanceMessage     String?
  allowNewRegistrations  Boolean   @default(true)
  createdAt              DateTime  @default(now())
  updatedAt              DateTime  @updatedAt
}

// =============================================================================
// ADMIN LOG
// =============================================================================

model AdminLog {
  id           String   @id @default(cuid())
  adminId      String
  action       String
  targetUserId String?
  targetId     String?
  targetType   String?
  description  String?
  previousData String?  @default("{}")
  newData      String?  @default("{}")
  ipAddress    String?
  userAgent    String?
  createdAt    DateTime @default(now())

  admin      User  @relation("AdminActor",  fields: [adminId],      references: [id])
  targetUser User? @relation("AdminTarget", fields: [targetUserId], references: [id])

  @@index([adminId])
  @@index([action])
  @@index([targetUserId])
  @@index([createdAt])
}

// =============================================================================
// AUDIT LOG
// =============================================================================

model AuditLog {
  id         String   @id @default(cuid())
  userId     String?
  action     String
  success    Boolean  @default(true)
  targetId   String?
  targetType String?
  ipAddress  String?
  userAgent  String?
  metadata   String   @default("{}")
  createdAt  DateTime @default(now())

  user User? @relation(fields: [userId], references: [id])

  @@index([userId])
  @@index([action])
  @@index([success])
  @@index([createdAt])
  @@index([userId, createdAt])
}

// =============================================================================
// PHYSICAL REDEMPTIONS
// status: PENDING | APPROVED | PREPARING | SHIPPED | DELIVERED | CANCELLED
// =============================================================================

model ShippingAddress {
  id          String   @id @default(cuid())
  userId      String
  fullName    String
  address     String
  city        String
  postalCode  String
  country     String
  phone       String?
  createdAt   DateTime @default(now())

  user         User                @relation(fields: [userId], references: [id])
  redemptions  PhysicalRedemption[]

  @@index([userId])
}

model PhysicalRedemption {
  id                String   @id @default(cuid())
  userId            String
  inventoryItemId   String
  cardId            String
  shippingAddressId String
  // status: PENDING | APPROVED | PREPARING | SHIPPED | DELIVERED | CANCELLED
  status            String   @default("PENDING")
  trackingNumber    String?
  adminNotes        String?
  createdAt         DateTime @default(now())
  updatedAt         DateTime @updatedAt

  user            User            @relation(fields: [userId], references: [id])
  card            Card            @relation(fields: [cardId], references: [id])
  shippingAddress ShippingAddress @relation(fields: [shippingAddressId], references: [id])

  @@index([userId])
  @@index([cardId])
  @@index([status])
  @@index([createdAt])
}
