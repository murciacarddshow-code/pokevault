# =============================================================================
# PokéVault — Variables de entorno
# Copia este archivo a .env.local y ajusta los valores
# =============================================================================

# ─── Base de datos (SQLite para desarrollo local) ─────────────────────────────
DATABASE_URL="file:./dev.db"

# ─── NextAuth v5 ──────────────────────────────────────────────────────────────
# OBLIGATORIO — genera uno con: openssl rand -base64 32
# o simplemente pon cualquier string largo y aleatorio
AUTH_SECRET="cambia-esto-por-algo-largo-y-secreto-32chars"
AUTH_URL="http://localhost:3000"

# ─── Stripe (OPCIONAL para demo local) ────────────────────────────────────────
# Si no tienes claves de Stripe, déjalo vacío.
# En modo demo, el botón "Recargar" añade saldo directamente sin pasar por Stripe.
STRIPE_SECRET_KEY=""
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=""
STRIPE_WEBHOOK_SECRET=""

# ─── Pokémon TCG API (OPCIONAL) ───────────────────────────────────────────────
# Solo necesario si quieres sincronizar precios reales
POKEMON_TCG_API_KEY=""

# ─── App ──────────────────────────────────────────────────────────────────────
NEXT_PUBLIC_APP_URL="http://localhost:3000"
